{
  "name": "npl-spec",
  "version": "1.0.0",
  "private": true,
  "description": "NPL open specification and reference implementation (Apache 2.0)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hardalion/npl-spec.git"
  },
  "scripts": {
    "build": "pnpm -r --filter @hardalion/npl-policy-engine --filter @hardalion/npl-audit-verify build",
    "test": "pnpm -r --filter @hardalion/npl-policy-engine --filter @hardalion/npl-audit-verify test",
    "test:coverage": "pnpm --filter @hardalion/npl-policy-engine test:coverage",
    "typecheck": "pnpm -r --filter @hardalion/npl-policy-engine --filter @hardalion/npl-audit-verify typecheck",
    "demo": "node -e \"require('child_process').execSync(process.platform==='win32'?'powershell -File examples/demo.ps1':'bash examples/demo.sh',{stdio:'inherit'})\""
  }
}
