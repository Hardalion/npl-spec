{
  "name": "@hardalion/npl-audit-verify",
  "version": "1.0.0",
  "description": "NPL offline audit hash-chain verifier (Apache 2.0)",
  "license": "Apache-2.0",
  "type": "module",
  "private": false,
  "bin": {
    "npl-audit-verify": "./dist/cli.js"
  },
