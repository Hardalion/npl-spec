{
  "name": "@hardalion/npl-policy-engine",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "NPL reference policy evaluator: deterministic AI agent governance (Apache 2.0)",
  "license": "Apache-2.0",
  "bin": {
    "npl-eval": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build",
    "lint": "echo Skipping lint"
  },
  "dependencies": {
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hardalion/npl-spec.git",
    "directory": "packages/policy-engine"
  },
  "publishConfig": {
    "access": "public"
  }
}
